<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account - Prism</title>
    <link rel="stylesheet" href="/style.css">
    <script>
        window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
    </script>
    <script defer src="/_vercel/insights/script.js"></script>
</head>

<body>
    <!-- Background Effects -->
    <div class="bg-glow"></div>
    <div class="bg-glow-2"></div>

    <%- include('partials/header', { user: user }) %>
        <main class="main-content container">
            <h1 class="mb-8 font-heading">Settings</h1>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px;">

                <!-- Profile Section -->
                <div class="card-glass" style="height: fit-content;">
                    <h2 class="mb-6" style="font-size: 1.5rem;">Profile</h2>
                    <div class="flex flex-col gap-4">
                        <div>
                            <label class="form-label"
                                style="text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.8rem;">Name</label>
                            <div class="font-semibold" style="font-size: 1.1rem; color: #fff;">
                                <%= user.name %>
                            </div>
                        </div>
                        <div>
                            <label class="form-label"
                                style="text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.8rem;">Email</label>
                            <div class="font-semibold" style="font-size: 1.1rem; color: #fff;">
                                <%= user.email %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Integrations Section -->
                <div class="flex flex-col gap-6">
                    <h2 style="font-size: 1.5rem;">Integrations</h2>

                    <!-- Slack Card -->
                    <div class="card card-interactive flex items-center justify-between" style="padding: 32px;">
                        <div class="flex items-center gap-4">
                            <span style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px;"><svg width="32" height="32" viewBox="0 0 24 24" fill="#E01E5A"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.523 2.527 2.527 0 0 1 2.521 2.523v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.523-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/></svg></span>
                            <div>
                                <h3 class="font-heading mb-2">Slack</h3>
                                <p class="text-secondary text-sm">Connect to search messages</p>
                            </div>
                        </div>
                        <div>
                            <% if (slackConnected) { %>
                                <span class="badge badge-slack">Connected</span>
                                <% } else { %>
                                    <a href="/auth/slack" class="btn btn-secondary text-sm"
                                        style="padding: 8px 16px;">Connect</a>
                                    <% } %>
                        </div>
                    </div>

                    <!-- Notion Card -->
                    <div class="card card-interactive flex items-center justify-between" style="padding: 32px;">
                        <div class="flex items-center gap-4">
                            <span style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px;"><svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M4.459 4.208c.745-.186 1.118-.558 1.118-1.118V1.6H2.04v1.49c0 .56.373.932 1.118 1.118.56.111.932.373.932.932v12.288c0 .56-.372.932-.932 1.118-.745.186-1.118.56-1.118 1.118v1.49h7.45v-1.49c0-.558-.372-.932-1.118-1.118-.56-.186-.932-.558-.932-1.118V6.816l8.94 11.73h2.61V6.257c0-.56.372-.932 1.117-1.118.746-.186 1.118-.558 1.118-1.118V2.53h-7.078v1.49c0 .56.373.932 1.118 1.118.56.186.932.558.932 1.118v10.424L6.694 4.58H4.46v-.372z"/></svg></span>
                            <div>
                                <h3 class="font-heading mb-2">Notion</h3>
                                <p class="text-secondary text-sm">Connect to search pages</p>
                            </div>
                        </div>
                        <div>
                            <% if (notionConnected) { %>
                                <span class="badge badge-notion">Connected</span>
                                <% } else { %>
                                    <a href="/auth/notion" class="btn btn-secondary text-sm"
                                        style="padding: 8px 16px;">Connect</a>
                                    <% } %>
                        </div>
                    </div>



                </div>
            </div>
        </main>
</body>

</html>