<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prism</title>
    <link rel="stylesheet" href="/style.css">
    <script>
        window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
    </script>
    <script defer src="/_vercel/insights/script.js"></script>
</head>

<body>
    <!-- Background Effects -->
    <div class="bg-glow"></div>
    <div class="bg-glow-2"></div>

    <%- include('partials/header', { user: user }) %>

        <main class="main-content container">
            <section class="text-center mb-12">
                <h1 class="mb-4 text-gradient">Prism</h1>
                <p class="text-secondary text-center mb-12"
                    style="font-size: 1.25rem; max-width: 600px; margin-left: auto; margin-right: auto;">
                    Seamlessly search across your Slack conversations and Notion documents in one sleek place.
                </p>

                <form action="/search" method="GET" class="search-container">
                    <div class="search-input-wrapper">
                        <input type="text" name="q" class="search-input" placeholder="What are you looking for...?"
                            value="<%= query %>" required autocomplete="off">
                        <button type="submit" class="btn btn-primary" style="margin: 4px;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8"></circle>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                            </svg>
                            Search
                        </button>
                    </div>
                </form>
            </section>

            <% if (typeof aiSummary !== 'undefined' && aiSummary) { %>
                <div class="ai-summary-card" style="
                    max-width: 900px;
                    margin: 0 auto 2rem auto;
                    background: linear-gradient(135deg, rgba(139, 92, 246, 0.12), rgba(59, 130, 246, 0.08));
                    border: 1px solid rgba(139, 92, 246, 0.3);
                    border-radius: 16px;
                    padding: 1.5rem 2rem;
                    position: relative;
                    overflow: hidden;
                ">
                    <!-- Glow accent -->
                    <div style="
                        position: absolute; top: 0; left: 0; right: 0; height: 2px;
                        background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.8), rgba(59, 130, 246, 0.8), transparent);
                    "></div>

                    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 0.875rem;">
                        <span style="font-size: 1.1rem;">✨</span>
                        <span style="
                            font-size: 0.75rem;
                            font-weight: 700;
                            letter-spacing: 0.1em;
                            text-transform: uppercase;
                            background: linear-gradient(90deg, #a78bfa, #60a5fa);
                            -webkit-background-clip: text;
                            -webkit-text-fill-color: transparent;
                            background-clip: text;
                        ">Prism AI Answer</span>
                    </div>

                    <p style="
                        color: var(--text-1, #e2e8f0);
                        font-size: 0.975rem;
                        line-height: 1.7;
                        margin: 0 0 1rem 0;
                    "><%= aiSummary %></p>

                    <div style="display: flex; align-items: center; gap: 6px;">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" style="opacity: 0.4;">
                            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"/>
                        </svg>
                        <span style="font-size: 0.7rem; color: var(--text-muted, #64748b); opacity: 0.7;">Synthesized by Gemini · Based on your connected sources</span>
                    </div>
                </div>
            <% } %>

            <% if (results) { %>
                <div class="results-grid mt-8">
                    <!-- Slack Column -->
                    <div class="column">
                        <div class="grid-column-title">
                            <span style="display: flex; align-items: center;"><img src="https://cdn.simpleicons.org/slack/E01E5A" width="22" height="22" alt="Slack"></span>
                            <h3 class="font-heading">Slack Results</h3>
                        </div>

                        <% if (results.slack && results.slack.length> 0) { %>
                            <div class="flex flex-col gap-4">
                                <% results.slack.forEach(item=> { %>
                                    <a href="<%= item.permalink %>" target="_blank" class="card card-interactive" style="border-left: 3px solid var(--slack);">
                                        <div class="flex items-center justify-between mb-4">
                                            <strong class="font-semibold" style="color: var(--text-1);">
                                                <%= item.user %>
                                            </strong>
                                            <span class="badge badge-slack">#<%= item.channel %></span>
                                        </div>
                                        <p class="text-secondary mb-4 line-clamp-3" style="font-size: 0.95rem;">
                                            <%= item.text %>
                                        </p>
                                        <span class="text-muted text-sm">
                                            <%= new Date(item.ts * 1000).toLocaleDateString() %>
                                        </span>
                                    </a>
                                    <% }) %>
                            </div>
                            <% } else { %>
                                <div class="card-glass text-center text-muted">
                                    No results found in Slack.
                                </div>
                                <% } %>
                    </div>

                    <!-- Notion Column -->
                    <div class="column">
                        <div class="grid-column-title">
                            <span style="display: flex; align-items: center;"><img src="https://cdn.simpleicons.org/notion/ffffff" width="22" height="22" alt="Notion"></span>
                            <h3 class="font-heading">Notion Results</h3>
                        </div>

                        <% if (results.notion && results.notion.length> 0) { %>
                            <div class="flex flex-col gap-4">
                                <% results.notion.forEach(item=> { %>
                                    <a href="<%= item.url %>" target="_blank" class="card card-interactive" style="border-left: 3px solid var(--notion);">
                                        <div class="flex items-center gap-3 mb-4">
                                            <span style="font-size: 1.25rem;">
                                                <%= item.icon || '📄' %>
                                            </span>
                                            <strong class="font-semibold" style="font-size: 1.1rem; color: var(--text-1);">
                                                <%= item.title %>
                                            </strong>
                                        </div>
                                        <div class="flex gap-2">
                                            <span class="badge badge-notion">
                                                <%= item.object %>
                                            </span>
                                        </div>
                                    </a>
                                    <% }) %>
                            </div>
                            <% } else { %>
                                <div class="card-glass text-center text-muted">
                                    No results found in Notion.
                                </div>
                                <% } %>
                    </div>

                    </div>
                <% } else if (typeof recents !=='undefined' && recents && recents.length> 0) { %>
                    <div style="max-width: 800px; margin: 60px auto 0;">
                        <div class="grid-column-title">
                            <span style="display: flex; align-items: center;"><img src="https://cdn.simpleicons.org/slack/E01E5A" width="22" height="22" alt="Slack"></span>
                            <h3 class="font-heading">Recent Slack Activity</h3>
                        </div>
                        <div class="flex flex-col gap-4">
                            <% recents.forEach(item=> { %>
                                <a href="<%= item.permalink %>" target="_blank" class="card card-interactive" style="border-left: 3px solid var(--slack);">
                                    <div class="flex items-center justify-between mb-4">
                                        <strong class="font-semibold" style="color: var(--text-1);">
                                            <%= item.user %>
                                        </strong>
                                        <span class="badge badge-slack">#<%= item.channel %></span>
                                    </div>
                                    <p class="text-secondary mb-4 line-clamp-3" style="font-size: 0.95rem;">
                                        <%= item.text %>
                                    </p>
                                    <span class="text-muted text-sm">
                                        <%= new Date(parseFloat(item.ts) * 1000).toLocaleDateString() %>
                                            <%= new Date(parseFloat(item.ts) * 1000).toLocaleTimeString([],
                                                {hour: '2-digit' , minute:'2-digit'}) %>
                                    </span>
                                </a>
                                <% }) %>
                        </div>
                    </div>
                    <% } %>
        </main>
</body>

</html>