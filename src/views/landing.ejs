<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prism - The Unified Knowledge Hub</title>
    <link rel="stylesheet" href="/style.css">
    
    <style>
        .hero {
            padding: 80px 0 60px;
            text-align: center;
            max-width: 800px;
            margin: 0 auto;
        }

        .hero h1 {
            font-size: 4rem;
            line-height: 1.1;
            margin-bottom: 24px;
        }

        .hero p {
            font-size: 1.25rem;
            color: var(--text-2);
            margin-bottom: 40px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 24px;
            margin-top: 60px;
            margin-bottom: 80px;
        }

        .feature-icon {
            font-size: 2.5rem;
            margin-bottom: 16px;
            display: inline-block;
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 3rem;
            }
        }
    </style>
</head>

<body>
    <!-- Background Effects -->
    <div class="bg-glow"></div>
    <div class="bg-glow-2"></div>

    <header>
        <div class="container flex items-center justify-between">
            <a href="/" class="font-heading font-bold text-xl flex items-center gap-2"
                style="color: var(--text-1); text-decoration: none;">
                <img id="logo-img" class="prism-logo" src="/02_prism_full_color_dark.jpg" alt="Prism Logo" style="height: 32px; width: auto; object-fit: contain;">
            </a>
            <div class="flex items-center gap-6">
                
                <a href="/login"
                    style="color: var(--text-2); text-decoration: none; font-weight: 500;">Login</a>
                <a href="/signup" class="btn btn-primary" style="padding: 10px 20px; font-size: 0.9rem;">Sign Up</a>
            </div>
        </div>
    </header>

    <main class="main-content container">
        <section class="hero">
            <h1 class="text-gradient">Connect your scattered knowledge</h1>
            <p>
                Prism brings your Slack conversations and Notion documents into one powerful, unified search experience.
                Stop digging, start finding.
            </p>

            <!-- Demo Search Bar -->
            <form action="/demo" method="GET" class="search-container" style="max-width: 640px; margin: 0 auto 16px;">
                <div class="search-input-wrapper">
                    <input type="text" name="q" class="search-input"
                        placeholder="Try searching 'pricing', 'roadmap', 'onboarding'..."
                        autocomplete="off">
                    <button type="submit" class="btn btn-primary" style="margin: 4px;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        Try Demo
                    </button>
                </div>
            </form>

            <!-- Suggestion Chips -->
            <div style="display: flex; justify-content: center; flex-wrap: wrap; gap: 8px; margin-bottom: 24px;">
                <span style="font-size: 0.78rem; color: var(--text-2); margin-right: 4px; line-height: 28px;">Try:</span>
                <% ['pricing', 'Q2 roadmap', 'onboarding', 'design system', 'marketing'].forEach(chip => { %>
                    <a href="/demo?q=<%= chip %>" style="
                        display: inline-block; padding: 5px 14px; border-radius: 20px; font-size: 0.8rem;
                        border: 1px solid rgba(255,255,255,0.12); color: var(--text-2); text-decoration: none;
                        background: rgba(255,255,255,0.04); transition: all 0.2s;
                    " onmouseover="this.style.borderColor='rgba(139,92,246,0.5)'; this.style.color='var(--text-1)'; this.style.background='rgba(139,92,246,0.08)'"
                       onmouseout="this.style.borderColor='rgba(255,255,255,0.12)'; this.style.color='var(--text-2)'; this.style.background='rgba(255,255,255,0.04)'"
                    ><%= chip %></a>
                <% }) %>
            </div>

            <p style="font-size: 0.78rem; color: var(--text-2); margin-bottom: 24px; opacity: 0.7;">
                No signup needed · or <a href="/signup" style="color: var(--primary); text-decoration: none; font-weight: 500;">create a free account →</a>
            </p>
        </section>


        <!-- What It Does Section -->
        <section class="mt-12 mb-12" style="padding-top: 40px;">
            <h2 class="section-title"><span>&gt;</span> What It Does</h2>

            <div class="grid-3">
                <!-- Card 1 -->
                <div class="card-glass p-6 text-left" style="padding: 32px;">
                    <span class="feature-icon mb-4" style="color: var(--primary);">🏠</span>
                    <h3 class="font-heading mb-2 text-xl" style="font-size: 1.25rem;">Unified Workspace</h3>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.6;">
                        Mac, Windows, or Linux. Connect all your fragmented knowledge bases. Private by default—your
                        data stays yours.
                    </p>
                </div>

                <!-- Card 2 -->
                <div class="card-glass p-6 text-left" style="padding: 32px;">
                    <span class="feature-icon mb-4" style="color: var(--primary);">💬</span>
                    <h3 class="font-heading mb-2 text-xl" style="font-size: 1.25rem;">Any Chat App</h3>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.6;">
                        Talk to it on Slack, Microsoft Teams, or Discord. Works seamlessly in DMs and group channels.
                    </p>
                </div>

                <!-- Card 3 -->
                <div class="card-glass p-6 text-left" style="padding: 32px;">
                    <span class="feature-icon mb-4" style="color: var(--primary);">🧠</span>
                    <h3 class="font-heading mb-2 text-xl" style="font-size: 1.25rem;">Persistent Memory</h3>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.6;">
                        Remembers your context and becomes uniquely yours. Your preferences, your history, your hub.
                    </p>
                </div>

                <!-- Card 4 -->
                <div class="card-glass p-6 text-left" style="padding: 32px;">
                    <span class="feature-icon mb-4" style="color: var(--primary);">⚡</span>
                    <h3 class="font-heading mb-2 text-xl" style="font-size: 1.25rem;">Blazing Fast</h3>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.6;">
                        Built for speed. Instantly index and retrieve information from thousands of Notion pages and
                        messages.
                    </p>
                </div>

                <!-- Card 5 -->
                <div class="card-glass p-6 text-left" style="padding: 32px;">
                    <span class="feature-icon mb-4" style="color: var(--primary);">🔒</span>
                    <h3 class="font-heading mb-2 text-xl" style="font-size: 1.25rem;">Secure Access</h3>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.6;">
                        Enterprise-grade security using standard OAuth2. We never store your search results
                        persistently.
                    </p>
                </div>

                <!-- Card 6 -->
                <div class="card-glass p-6 text-left" style="padding: 32px;">
                    <span class="feature-icon mb-4" style="color: var(--primary);">🧩</span>
                    <h3 class="font-heading mb-2 text-xl" style="font-size: 1.25rem;">Skills & Integrations</h3>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.6;">
                        Extend with our growing library of integrations. Build your custom workflows easily.
                    </p>
                </div>
            </div>
        </section>

        <!-- Works With Everything Section -->
        <section class="mb-12" style="padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.05);">
            <h2 class="section-title"><span>&gt;</span> Works With Everything</h2>

            <div class="integration-pill-container"
                style="justify-content: center; max-width: 900px; margin: 0 auto 40px;">
                <span class="integration-pill">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--slack)"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.523 2.527 2.527 0 0 1 2.521 2.523v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.523-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/></svg>  Slack
                </span>
                <span class="integration-pill">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M4.459 4.208c.745-.186 1.118-.558 1.118-1.118V1.6H2.04v1.49c0 .56.373.932 1.118 1.118.56.111.932.373.932.932v12.288c0 .56-.372.932-.932 1.118-.745.186-1.118.56-1.118 1.118v1.49h7.45v-1.49c0-.558-.372-.932-1.118-1.118-.56-.186-.932-.558-.932-1.118V6.816l8.94 11.73h2.61V6.257c0-.56.372-.932 1.117-1.118.746-.186 1.118-.558 1.118-1.118V2.53h-7.078v1.49c0 .56.373.932 1.118 1.118.56.186.932.558.932 1.118v10.424L6.694 4.58H4.46v-.372z"/></svg>  Notion
                </span>
                <span class="integration-pill">
                    <span style="color: #25D366;">WhatsApp</span>
                </span>
                <span class="integration-pill">
                    <span style="color: #0088cc;">Telegram</span>
                </span>
                <span class="integration-pill">
                    <span style="color: #5865F2;">Discord</span>
                </span>
                <span class="integration-pill">
                    <span style="color: #3B82F6;">iMessage</span>
                </span>
                <span class="integration-pill">
                    <span style="color: #1DB954;">Spotify</span>
                </span>
                <span class="integration-pill">
                    <span style="color: #A855F7;">Obsidian</span>
                </span>
                <span class="integration-pill">
                    <span style="color: var(--text-1);">𝕏</span> Twitter
                </span>
                <span class="integration-pill">
                    <span style="color: #4285F4;">Browser</span>
                </span>
                
                <span class="integration-pill">
                    <span style="color: var(--text-1);">GitHub</span>
                </span>
            </div>

            <div class="text-center mt-6">
                <a href="/login" style="color: var(--primary); text-decoration: none; font-weight: 500;">View all
                    integrations &rarr;</a>
            </div>
        </section>

        <footer class="text-center text-muted"
            style="padding-top: 40px; border-top: 1px solid var(--border); margin-bottom: 40px;">
            <p>&copy; 2026 Prism. Built with ♥️.</p>
        </footer>
    </main>

    
</body>

</html>