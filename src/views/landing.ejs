<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prism - The Unified Knowledge Hub</title>
    <link rel="stylesheet" href="/style.css">
    <script>
        window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
    </script>
    <script defer src="/_vercel/insights/script.js"></script>
    <script>
        // Set theme immediately to avoid FOUC
        (function () {
            const savedTheme = localStorage.getItem('theme');
            const prefersLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
            let currentTheme = savedTheme || (prefersLight ? 'light' : 'dark');
            if (currentTheme === 'light') {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>
    <style>
        .hero {
            padding: 80px 0 60px;
            text-align: center;
            max-width: 800px;
            margin: 0 auto;
        }

        .hero h1 {
            font-size: 4rem;
            line-height: 1.1;
            margin-bottom: 24px;
        }

        .hero p {
            font-size: 1.25rem;
            color: var(--text-2);
            margin-bottom: 40px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 24px;
            margin-top: 60px;
            margin-bottom: 80px;
        }

        .feature-icon {
            font-size: 2.5rem;
            margin-bottom: 16px;
            display: inline-block;
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 3rem;
            }
        }
    </style>
</head>

<body>
    <!-- Background Effects -->
    <div class="bg-glow"></div>
    <div class="bg-glow-2"></div>

    <header>
        <div class="container flex items-center justify-between">
            <a href="/" class="font-heading font-bold text-xl flex items-center gap-2"
                style="color: var(--text-1); text-decoration: none;">
                <img id="logo-img" src="/05_prism_white_knockout.jpg" alt="Prism Logo" style="height: 32px; width: auto; object-fit: contain;">
            </a>
            <div class="flex items-center gap-6">
                <!-- Theme Toggle Button -->
                <button id="theme-toggle" aria-label="Toggle Theme"
                    style="background: transparent; border: 1px solid var(--border); padding: 8px; border-radius: 50%; color: var(--text-1); display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; cursor: pointer; transition: all 0.2s;">
                    <svg id="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
                        <circle cx="12" cy="12" r="5"></circle>
                        <line x1="12" y1="1" x2="12" y2="3"></line>
                        <line x1="12" y1="21" x2="12" y2="23"></line>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                        <line x1="1" y1="12" x2="3" y2="12"></line>
                        <line x1="21" y1="12" x2="23" y2="12"></line>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                    </svg>
                    <svg id="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                    </svg>
                </button>
                <a href="/login"
                    style="color: var(--text-2); text-decoration: none; font-weight: 500;">Login</a>
                <a href="/signup" class="btn btn-primary" style="padding: 10px 20px; font-size: 0.9rem;">Sign Up</a>
            </div>
        </div>
    </header>

    <main class="main-content container">
        <section class="hero">
            <h1 class="text-gradient">Connect your scattered knowledge</h1>
            <p>
                Prism brings your Slack conversations and Notion documents into one powerful, unified search experience.
                Stop digging, start finding.
            </p>
            <div class="flex items-center justify-center gap-4">
                <a href="/signup" class="btn btn-primary" style="font-size: 1.1rem; padding: 16px 32px;">Get Started for
                    Free</a>
            </div>
        </section>

        <!-- What It Does Section -->
        <section class="mt-12 mb-12" style="padding-top: 40px;">
            <h2 class="section-title"><span>&gt;</span> What It Does</h2>

            <div class="grid-3">
                <!-- Card 1 -->
                <div class="card-glass p-6 text-left" style="padding: 32px;">
                    <span class="feature-icon mb-4" style="color: var(--primary);">🏠</span>
                    <h3 class="font-heading mb-2 text-xl" style="font-size: 1.25rem;">Unified Workspace</h3>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.6;">
                        Mac, Windows, or Linux. Connect all your fragmented knowledge bases. Private by default—your
                        data stays yours.
                    </p>
                </div>

                <!-- Card 2 -->
                <div class="card-glass p-6 text-left" style="padding: 32px;">
                    <span class="feature-icon mb-4" style="color: var(--primary);">💬</span>
                    <h3 class="font-heading mb-2 text-xl" style="font-size: 1.25rem;">Any Chat App</h3>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.6;">
                        Talk to it on Slack, Microsoft Teams, or Discord. Works seamlessly in DMs and group channels.
                    </p>
                </div>

                <!-- Card 3 -->
                <div class="card-glass p-6 text-left" style="padding: 32px;">
                    <span class="feature-icon mb-4" style="color: var(--primary);">🧠</span>
                    <h3 class="font-heading mb-2 text-xl" style="font-size: 1.25rem;">Persistent Memory</h3>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.6;">
                        Remembers your context and becomes uniquely yours. Your preferences, your history, your hub.
                    </p>
                </div>

                <!-- Card 4 -->
                <div class="card-glass p-6 text-left" style="padding: 32px;">
                    <span class="feature-icon mb-4" style="color: var(--primary);">⚡</span>
                    <h3 class="font-heading mb-2 text-xl" style="font-size: 1.25rem;">Blazing Fast</h3>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.6;">
                        Built for speed. Instantly index and retrieve information from thousands of Notion pages and
                        messages.
                    </p>
                </div>

                <!-- Card 5 -->
                <div class="card-glass p-6 text-left" style="padding: 32px;">
                    <span class="feature-icon mb-4" style="color: var(--primary);">🔒</span>
                    <h3 class="font-heading mb-2 text-xl" style="font-size: 1.25rem;">Secure Access</h3>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.6;">
                        Enterprise-grade security using standard OAuth2. We never store your search results
                        persistently.
                    </p>
                </div>

                <!-- Card 6 -->
                <div class="card-glass p-6 text-left" style="padding: 32px;">
                    <span class="feature-icon mb-4" style="color: var(--primary);">🧩</span>
                    <h3 class="font-heading mb-2 text-xl" style="font-size: 1.25rem;">Skills & Integrations</h3>
                    <p class="text-secondary" style="font-size: 0.95rem; line-height: 1.6;">
                        Extend with our growing library of integrations. Build your custom workflows easily.
                    </p>
                </div>
            </div>
        </section>

        <!-- Works With Everything Section -->
        <section class="mb-12" style="padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.05);">
            <h2 class="section-title"><span>&gt;</span> Works With Everything</h2>

            <div class="integration-pill-container"
                style="justify-content: center; max-width: 900px; margin: 0 auto 40px;">
                <span class="integration-pill">
                    <span style="color: var(--slack);">#</span> Slack
                </span>
                <span class="integration-pill">
                    <span>📝</span> Notion
                </span>
                <span class="integration-pill">
                    <span style="color: #25D366;">WhatsApp</span>
                </span>
                <span class="integration-pill">
                    <span style="color: #0088cc;">Telegram</span>
                </span>
                <span class="integration-pill">
                    <span style="color: #5865F2;">Discord</span>
                </span>
                <span class="integration-pill">
                    <span style="color: #3B82F6;">iMessage</span>
                </span>
                <span class="integration-pill">
                    <span style="color: #1DB954;">Spotify</span>
                </span>
                <span class="integration-pill">
                    <span style="color: #A855F7;">Obsidian</span>
                </span>
                <span class="integration-pill">
                    <span style="color: var(--text-1);">𝕏</span> Twitter
                </span>
                <span class="integration-pill">
                    <span style="color: #4285F4;">Browser</span>
                </span>
                <span class="integration-pill">
                    <span style="color: #EA4335;">Gmail</span>
                </span>
                <span class="integration-pill">
                    <span style="color: var(--text-1);">GitHub</span>
                </span>
            </div>

            <div class="text-center mt-6">
                <a href="/login" style="color: var(--primary); text-decoration: none; font-weight: 500;">View all
                    integrations &rarr;</a>
            </div>
        </section>

        <footer class="text-center text-muted"
            style="padding-top: 40px; border-top: 1px solid var(--border); margin-bottom: 40px;">
            <p>&copy; 2026 Prism. Built with ♥️.</p>
        </footer>
    </main>

    <script>
        window.addEventListener('DOMContentLoaded', () => {
            const toggleBtn = document.getElementById('theme-toggle');
            const iconSun = document.getElementById('icon-sun');
            const iconMoon = document.getElementById('icon-moon');

            function updateIcon(theme) {
                const logoImg = document.getElementById('logo-img');
                if (theme === 'light') {
                    if (iconSun) iconSun.style.display = 'none';
                    if (iconMoon) iconMoon.style.display = 'block';
                    if (logoImg) logoImg.src = '/01_prism_full_color.jpg';
                } else {
                    if (iconSun) iconSun.style.display = 'block';
                    if (iconMoon) iconMoon.style.display = 'none';
                    if (logoImg) logoImg.src = '/05_prism_white_knockout.jpg';
                }
            }

            updateIcon(document.documentElement.getAttribute('data-theme') || 'dark');

            if (toggleBtn) {
                toggleBtn.addEventListener('click', () => {
                    let newTheme = 'dark';
                    if (document.documentElement.getAttribute('data-theme') !== 'light') {
                        newTheme = 'light';
                        document.documentElement.setAttribute('data-theme', 'light');
                    } else {
                        document.documentElement.removeAttribute('data-theme');
                    }
                    localStorage.setItem('theme', newTheme);
                    updateIcon(newTheme);
                });
            }
        });
    </script>
</body>

</html>