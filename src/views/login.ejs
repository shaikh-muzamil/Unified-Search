<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Unified Search</title>
    <link rel="stylesheet" href="/style.css">
    <script>
        window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
    </script>
    <script defer src="/_vercel/insights/script.js"></script>
</head>

<body>
    <!-- Background Effects -->
    <div class="bg-glow"></div>
    <div class="bg-glow-2"></div>

    <%- include('partials/header', { user: null }) %>
        <main class="main-content container">
            <div class="card-glass" style="max-width: 440px; margin: 40px auto 0; padding: 40px;">
                <h2 class="text-center mb-6 font-heading">Welcome Back</h2>

                <% if (locals.error) { %>
                    <div class="badge badge-error text-center mb-6" style="display: block; padding: 8px;">
                        <%= error %>
                    </div>
                    <% } %>

                        <form action="/login" method="POST" class="flex flex-col gap-4">
                            <div class="form-group mb-2">
                                <label class="form-label"
                                    style="text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.8rem;">Email</label>
                                <input type="email" name="email" required placeholder="name@example.com">
                            </div>
                            <div class="form-group mb-4">
                                <div class="flex justify-between items-center mb-2">
                                    <label class="form-label"
                                        style="text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.8rem; margin:0;">Password</label>
                                    <!-- <a href="#" class="text-sm">Forgot?</a> -->
                                </div>
                                <input type="password" name="password" required placeholder="••••••••">
                            </div>
                            <button type="submit" class="btn btn-primary w-full mt-2"
                                style="padding: 16px;">Login</button>
                        </form>

                        <p class="text-center mt-6 text-secondary" style="font-size: 0.95rem;">
                            Don't have an account? <a href="/signup">Sign up</a>
                        </p>
            </div>
        </main>
</body>

</html>